            s = Gtk.Label(label=sub); s.set_xalign(0); s.get_style_context().add_class("fcard-s"); box.pack_start(s, False, False, 0)
        return box

    def _run_async(self, fn, done=None):
        def work():
            out = fn()
            if done: GLib.idle_add(lambda: (done(out), False)[1])
        threading.Thread(target=work, daemon=True).start()

