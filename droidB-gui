        boot = self._pick("boot.img to patch with Magisk")
        if not boot: return
        self.mod_out.set_text("patching with Magisk → %s_magisk.img (watch the terminal)" % os.path.splitext(boot)[0])
        self._termrun("Magisk patch", "droidB-mod magisk-patch %s" % shlex.quote(boot))

    def _fb_flash_part(self, part):
        img = self._pick("%s image (fastboot)" % part)
        if not img: return
        if not self._confirm("Flash %s" % part, "fastboot flash %s '%s'? Can brick." % (part, os.path.basename(img))): return
        self._run_async(lambda: fastboot("flash", part, img, timeout=300), lambda r: self.mod_out.set_text(r or "flash done"))

    def _boot_img(self, *_):
        img = self._pick("image to boot temporarily")
        if not img: return
        self._run_async(lambda: fastboot("boot", img, timeout=120), lambda r: self.mod_out.set_text(r or "booting…"))

    def _flash_gsi(self, *_):
        img = self._pick("GSI system image (.img)")
        if not img: return
        if not self._confirm("Flash GSI", "Flash this GSI to 'system' and wipe userdata? The device must be unlocked + in fastboot."):
            return
        def run():
            fastboot("--disable-verity", "--disable-verification", "flash", "system", img, timeout=400)
            fastboot("-w", timeout=60); return "GSI flashed + data wiped - reboot the device"
        self.mod_out.set_text("flashing GSI…"); self._run_async(run, self.mod_out.set_text)

    def _sideload(self, *_):
        z = self._pick("ROM .zip to sideload (device: recovery → Apply update → from ADB)")
        if not z: return
        self._termrun("sideload ROM", "adb sideload %s" % shlex.quote(z))

    def _fb_update(self, *_):
        z = self._pick("fastboot update package (.zip)")
        if not z: return
        if not self._confirm("Fastboot update", "fastboot update '%s'? Can brick." % os.path.basename(z)): return
        self._termrun("fastboot update", "fastboot update %s" % shlex.quote(z))

    def _extract(self, kind):
        f = self._pick("payload.bin or OTA .zip" if kind == "payload" else "super.img")
        if not f: return
        out = os.path.join(self._outdir(), kind)
        self.mod_out.set_text("extracting → %s (watch the terminal)" % out)
        self._termrun(kind + " extract", "droidB-mod %s %s %s" % (kind, shlex.quote(f), shlex.quote(out)))


