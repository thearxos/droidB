    def _p_device(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.pack_start(self._hdr("Device", "live state, properties and reboot"), False, False, 0)
        self.dev_info = Gtk.Label(label="connect a device…"); self.dev_info.set_xalign(0)
        self.dev_info.get_style_context().add_class("mono"); self.dev_info.set_selectable(True)
        box.pack_start(self._scroller(self.dev_info), True, True, 0)
        row = Gtk.Box(spacing=8)
        row.pack_start(self._act("Refresh", lambda *_: self._load_devinfo()), False, False, 0)
        self.reboot_to = Gtk.ComboBoxText()
        for x in ("system","recovery","bootloader","fastboot","sideload"): self.reboot_to.append_text(x)
        self.reboot_to.set_active(0); row.pack_start(self.reboot_to, False, False, 0)
        row.pack_start(self._act("Reboot", self._reboot), False, False, 0)
        box.pack_start(row, False, False, 0)
        GLib.timeout_add(800, lambda: (self._load_devinfo(), False)[1])
        return box

    def _load_devinfo(self):
        if self._state() != "device":
            self.dev_info.set_text("no device connected."); return
        self.dev_info.set_text("reading…")
        def read():
            g = lambda k: adb("shell", "getprop", k, timeout=5)
            batt = adb("shell", "dumpsys", "battery", timeout=6)
            lvl = next((l.split(":")[1].strip() for l in batt.splitlines() if "level" in l), "?")
            store = adb("shell", "df", "-h", "/data", timeout=6).splitlines()
            store = store[-1] if len(store) > 1 else ""
            return ("Model     %s\nBrand     %s\nDevice    %s\nAndroid   %s  (API %s)\n"
                    "Security  %s\nSoC       %s\nABI       %s\nSerial    %s\nBattery   %s%%\nStorage   %s") % (
                g("ro.product.model"), g("ro.product.brand"), g("ro.product.device"),
                g("ro.build.version.release"), g("ro.build.version.sdk"),
                g("ro.build.version.security_patch"), g("ro.board.platform") or g("ro.hardware"),
                g("ro.product.cpu.abi"), adb("get-serialno", timeout=4), lvl,
                " ".join(store.split()[1:5]) if store else "?")
        self._run_async(read, self.dev_info.set_text)

    def _reboot(self, *_):
        if self._state() not in ("device",): self._msg("No device", "No device connected."); return
        mode = self.reboot_to.get_active_text()
        self._run_async(lambda: adb("reboot", "" if mode == "system" else mode))

