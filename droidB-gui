#!/usr/bin/env python3
# droidB-gui 0.0.1 - ARXOS Android Toolkit (GTK3, fully graphical).
# Every feature is GUI: real-time device state, apps, live logcat, files, screen,
# fastboot, an in-window adb shell, and MediaTek/Samsung flashing. adb/fastboot are
# the engine for now; the hot device-IO paths get a low-level (Go/Rust) core later.
import gi, subprocess, threading, os, sys, time, shlex
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GLib, Pango

VERSION = "0.0.1"
GREEN = "#3ddc84"

